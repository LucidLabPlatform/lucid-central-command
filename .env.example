# =============================================================================
# LUCID Central Command — Canonical Environment Example
# =============================================================================
# This file documents the full environment surface across:
# - lucid-infra
# - lucid-orchestrator
# - lucid-ui
# - lucid-ai
#
# Most day-to-day deployments use these values through `lucid-infra/.env`.
# The variables below are grouped so one file captures both:
# - operator-supplied secrets and settings
# - internal service URLs used when running services standalone
# =============================================================================

# -- Shared database ----------------------------------------------------------
POSTGRES_DB=lucid
POSTGRES_USER=lucid
POSTGRES_PASSWORD=change-me-postgres-password

# -- EMQX dashboard + management API -----------------------------------------
EMQX_API_USERNAME=lucid
EMQX_API_PASSWORD=change-me-emqx-admin-password

# -- Central Command MQTT identity -------------------------------------------
LUCID_MQTT_USERNAME=central-command
LUCID_MQTT_PASSWORD=change-me-central-command-mqtt-password

# -- Shared service URLs ------------------------------------------------------
# These are mostly wired by docker-compose, but are listed here so standalone
# runs of the submodules can use the same canonical values.
LUCID_MQTT_HOST=emqx
LUCID_MQTT_PORT=1883
LUCID_DB_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
EMQX_API_URL=http://emqx:18083/api/v5
LUCID_AUTH_URL=http://auth:4000
ORCHESTRATOR_URL=http://lucid-orchestrator:5000
LUCID_FLEET_CORE_URL=http://lucid-orchestrator:5000
AI_URL=http://lucid-ai:5000

# -- lucid-ui -----------------------------------------------------------------
# `FLEET_CORE_URL` is kept for compatibility with existing UI/full-stack code.
FLEET_CORE_URL=http://lucid-orchestrator:5000
DASHBOARD_PASSWORD=change-me-dashboard-password
SESSION_SECRET=change-me-session-secret
LDAP_URL=
LDAP_BIND_DN_TEMPLATE=
LUCID_UI_ENABLE_EXPERIMENTS=true
LUCID_UI_ENABLE_AI=true

# -- Optional EMQX LDAP authentication ---------------------------------------
# Leave blank to disable LDAP in the broker.
LDAP_SERVER=
LDAP_BIND_USERNAME=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=
LDAP_FILTER=

# -- lucid-ai -----------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
AI_MAX_ITERATIONS=15
AI_CHAT_TIMEOUT=60
